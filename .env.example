NODE_ENV=development
PORT=4000
LOG_LEVEL=info

DATABASE_URL="mysql://root:password@localhost:3306/lit_test"

JWT_ACCESS_TOKEN_SECRET="change-this-access-secret-to-at-least-32-characters"
JWT_REFRESH_TOKEN_SECRET="change-this-refresh-secret-to-at-least-32-characters"
JWT_ACCESS_TOKEN_EXPIRES_IN="1h"
JWT_REFRESH_TOKEN_EXPIRES_IN="30d"

CORS_ORIGIN="http://localhost:3000"

SWAGGER_ENABLED=true
SWAGGER_PATH="docs"

AUTH_RATE_LIMIT_TTL=900000
AUTH_RATE_LIMIT_LIMIT=5

EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=""
EMAIL_PASSWORD=""
EMAIL_FROM="Life is Travel <contact@lifeistravel.io>"
EMAIL_VERIFICATION_CODE_LENGTH=6
EMAIL_VERIFICATION_CODE_EXPIRES_IN=180
EMAIL_VERIFICATION_MAX_ATTEMPTS=5

ADMIN_FEEDBACK_TOKEN="replace-this-with-32-plus-char-random-token"
FEEDBACK_IP_HASH_SECRET="replace-this-with-32-plus-char-random-secret"

# 카카오 REST API 키 (https://developers.kakao.com → 내 애플리케이션 → 앱 키 → REST API 키)
# 주소 검색 및 지오코딩에 사용
KAKAO_REST_API_KEY=""

# Cloudflare R2 Object Storage (S3 호환)
# https://dash.cloudflare.com → R2 → Manage R2 API Tokens에서 발급
CF_R2_ACCOUNT_ID=""
CF_R2_BUCKET="lit-server"
CF_R2_ACCESS_KEY_ID=""
CF_R2_SECRET_ACCESS_KEY=""
# 버킷 Public Access 활성화 시 설정 (예: https://pub-xxxx.r2.dev 또는 커스텀 도메인)
# CF_R2_PUBLIC_URL=""
